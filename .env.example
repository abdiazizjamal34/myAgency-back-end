# ─── Core ─────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/your-db-name
TZ=Africa/Addis_Ababa
ALLOWED_ORIGINS=http://localhost:5173
FRONTEND_URL=https://yourdomain.com/
APP_BASE_URL=https://yourdomain.com/billing
APP_NAME=YourAppName
SUPPORT_EMAIL=your-support@example.com
DEFAULT_UNIT_PRICE=35
DEFAULT_CURRENCY=ETB

# ─── Auth / JWT ───────────────────────────────────────────────────
JWT_SECRET=change-me-use-a-long-random-string
JWT_EXPIRES_IN=7d

# ─── Seed credentials (npm run seed:superadmin) ───────────────────
SEED_SUPERADMIN_NAME=Super Admin
SEED_SUPERADMIN_EMAIL=superadmin@example.com
SEED_SUPERADMIN_PASSWORD=ChangeMe123!

# ─── AI / Normalization ───────────────────────────────────────────
# NORMALIZATION_PROVIDER: "gemini" (default) or "openai"
NORMALIZATION_PROVIDER=gemini

GEMINI_API_KEY=your-gemini-api-key
GEMINI_NORMALIZATION_MODELS=gemini-2.5-flash
GEMINI_NORMALIZATION_MAX_ATTEMPTS=3
GEMINI_NORMALIZATION_RETRY_BASE_MS=800

OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_NORMALIZATION_MODELS=gpt-4.1-mini
OPENAI_NORMALIZATION_MAX_ATTEMPTS=3
OPENAI_NORMALIZATION_RETRY_BASE_MS=800

# ─── Email (SMTP) ─────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
MAILBOXLAYER_API_KEY=your-mailboxlayer-key

# ─── Billing ──────────────────────────────────────────────────────
BILLING_JOBS_ENABLED=true

# ─── WhatsApp (Twilio Cloud API) ──────────────────────────────────
WHATSAPP_PHONE_ID=your-whatsapp-phone-id
WHATSAPP_TOKEN=your-whatsapp-api-token
